{
  "name": "clickup-task-mcp",
  "version": "1.0.0",
  "description": "Model Context Protocol (MCP) server for ClickUp — manage tasks, track time, and post daily updates from Claude Code, Cursor, or any MCP-compatible AI tool.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "clickup-task-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "clickup",
    "task-management",
    "time-tracking",
    "claude",
    "claude-code",
    "cursor",
    "ai-tools",
    "chat",
    "daily-update"
  ],
  "author": "Arslan Asghar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arslan8122/clickup-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/arslan8122/clickup-mcp/issues"
  },
  "homepage": "https://github.com/arslan8122/clickup-mcp#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "clickup-task-mcp": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3"
  }
}
